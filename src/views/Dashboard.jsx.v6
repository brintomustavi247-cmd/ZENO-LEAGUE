      </div>

      {/* Divider */}
      <div style={{ width: 1, height: 14, background: 'rgba(255,255,255,0.1)' }} />

      {/* Level */}
      <div style={{
        display: 'flex',
        alignItems: 'center',
        gap: 6,
        fontSize: 11,
        fontWeight: 600,
        color: tierInfo?.color || '#a855f7',
      }}>
        <i className="fa-solid fa-star" />
        Lv {tierInfo?.level || 1}
