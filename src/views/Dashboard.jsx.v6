function DailyQuestsBanner({ quests, onViewAll }) {
  if (!quests || quests.length === 0) {
    return null
  }

  const completed = quests.filter(q => q.progress >= q.target).length
  const completionRate = Math.round((completed / quests.length) * 100)

  return (
    <div
      onClick={onViewAll}
      style={{
        padding: '14px 16px',
        background: 'linear-gradient(135deg, rgba(34,197,94,0.1), rgba(74,222,128,0.05))',
        border: '1px solid rgba(34,197,94,0.2)',
        borderRadius: 12,
        marginBottom: 20,
        cursor: 'pointer',
        transition: 'all 0.2s ease',
      }}
      onMouseEnter={e => {
        e.currentTarget.style.background = 'linear-gradient(135deg, rgba(34,197,94,0.15), rgba(74,222,128,0.08))'
        e.currentTarget.style.borderColor = 'rgba(34,197,94,0.4)'
      }}
      onMouseLeave={e => {
        e.currentTarget.style.background = 'linear-gradient(135deg, rgba(34,197,94,0.1), rgba(74,222,128,0.05))'
        e.currentTarget.style.borderColor = 'rgba(34,197,94,0.2)'
      }}
    >
      <div style={{ display: 'flex', alignItems: 'center', gap: 12, justifyContent: 'space-between' }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
          <i className="fa-solid fa-clipboard-list" style={{ fontSize: 16, color: '#22c55e', flexShrink: 0 }} />
          <div>
            <div style={{ fontSize: 12, fontWeight: 700, color: '#fff', marginBottom: 2 }}>
              Daily Quests
            </div>
            <div style={{ fontSize: 10, color: 'var(--text-muted)' }}>
              {completed}/{quests.length} completed • {completionRate}% done
            </div>
          </div>
        </div>
        <i className="fa-solid fa-chevron-right" style={{ color: 'var(--text-muted)', fontSize: 12, flexShrink: 0 }} />
      </div>
    </div>
  )
}

export default function Dashboard() {
  const { state, dispatch } = useApp()
  const { currentUser, matches, tierInfo, dailyQuests } = state

  if (!currentUser) {
    return <div style={{ padding: 20, color: '#999' }}>Loading...</div>
  }

  const heroMatch = matches?.[0]
  const allMatches = matches || []

  const handleJoinMatch = (matchId, showDetail = false) => {
    if (showDetail) {
      dispatch({ type: 'SHOW_MODAL', payload: 'match-detail', matchId })
    } else {
      dispatch({ type: 'SHOW_MODAL', payload: 'join-match', matchId })
    }
  }

  const handleDeposit = () => {
    dispatch({ type: 'SHOW_MODAL', payload: 'add-money' })
  }

  const handleWithdraw = () => {
    const lockedBalance = currentUser?.lockedBalance || 0
    if (lockedBalance > 0) {
      dispatch({ type: 'SHOW_TOAST', payload: {
        id: 'withdraw_locked_' + Date.now(),
        type: 'warning',
        text: `You have ${formatTK(lockedBalance)} TK locked in Arena Credit. Use it in matches first!`,
        removing: false,
      }})
      return
    }
    dispatch({ type: 'SHOW_MODAL', payload: 'withdraw' })
  }

  const handleViewQuests = () => {
    dispatch({ type: 'NAVIGATE', payload: { path: '/profile', tab: 'quests' } })
  }

  return (
    <div style={{ padding: '0 0 100px 0' }}>
      {/* ═══ STATUS BAR ═══ */}
      <StatusBar currentUser={currentUser} tierInfo={tierInfo} />

      {/* ═══ BALANCE CARD ═══ */}
      <BalanceCard
        currentUser={currentUser}
        onDeposit={handleDeposit}
        onWithdraw={handleWithdraw}
      />

      {/* ═══ HERO FEATURED MATCH ═══ */}
      {heroMatch && (
        <HeroMatchCard
          match={heroMatch}
          currentUser={currentUser}
          onJoin={handleJoinMatch}
        />
      )}

      {/* ═══ RECENT WINNERS ═══ */}
      <RecentWinnersPanel matches={allMatches} />

      {/* ═══ FILLING FAST ═══ */}
      <FillingFastPanel
        matches={allMatches}
        currentUser={currentUser}
        onJoin={handleJoinMatch}
      />

      {/* ═══ YOUR STATS GRID ═══ */}
      <YourStatsGrid currentUser={currentUser} />

      {/* ═══ ADMIN NOTICE ═══ */}
      <AdminNoticePanel />

      {/* ═══ DAILY QUESTS BANNER ═══ */}
      <DailyQuestsBanner quests={dailyQuests} onViewAll={handleViewQuests} />

      {/* ═══ RECOMMENDED MATCHES ═══ */}
      {allMatches.length > 1 && (
        <div>
          <h2 style={{
            fontFamily: 'var(--font-heading)',
            fontSize: 14,
            fontWeight: 700,
            color: '#fff',
            margin: '0 0 14px',
            textTransform: 'uppercase',
            letterSpacing: '0.05em',
          }}>
            Recommended For You
          </h2>

          <div style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))',
            gap: 14,
          }}>
            {allMatches.slice(1, 4).map(m => (
              <MatchCard
                key={m.id}
                match={m}
                currentUser={currentUser}
                onJoin={() => handleJoinMatch(m.id)}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  )
}
