rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      let d = getUserData();
      return d != null && d.role == 'owner';
    }

    function isAdminOrOwner() {
      let d = getUserData();
      return d != null && (d.role == 'admin' || d.role == 'owner');
    }

    function hasPermission(perm) {
      let d = getUserData();
      if (d != null && d.role == 'owner') return true;
      if (d != null && d.role == 'admin') return perm in d.permissions;
      return false;
    }

    function isSensitiveFieldChanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return 'role' in changed
        || 'banned' in changed
        || 'status' in changed
        || 'permissions' in changed
        || 'forcePasswordChange' in changed;
    }

    // ── USERS ──

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAdminOrOwner();
      allow update: if isAuthenticated() && request.auth.uid == userId && !isSensitiveFieldChanged() && !('balance' in request.resource.data.diff(resource.data).affectedKeys()) && !('lockedBalance' in request.resource.data.diff(resource.data).affectedKeys());
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'lockedBalance']);
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lockedBalance']);
      allow delete: if false;

      match /notifications/{notifId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAdminOrOwner();
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    // ── MATCHES ──

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow update: if isAuthenticated() && resource.data.status == 'upcoming' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joined', 'participants', 'joinedCount', 'escrow']);
      allow delete: if false;
    }

    // ── TRANSACTIONS ──

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if false;
    }

    // ── ADD MONEY REQUESTS ──

    match /addMoneyRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdminOrOwner();
      allow delete: if false;
    }

    // ── WITHDRAWALS ──

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdminOrOwner());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdminOrOwner();
      allow delete: if false;
    }

    // ── REFERRALS ──

    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdminOrOwner();
      allow delete: if false;
    }

    // ── SPIN LOG ──

    match /spinLog/{spinId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── AD REWARDS ──

    match /adRewards/{adId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── ACTIVITY LOG ──

    match /activityLog/{logId} {
      allow read: if isOwner();
      allow create: if isAdminOrOwner();
      allow update: if false;
      allow delete: if false;
    }

    // ── SETTINGS ──

    match /settings/global {
      allow read: if isAuthenticated();
      allow create: if isOwner();
      allow update: if isOwner() || hasPermission('payments');
      allow delete: if false;
    }
  }
}